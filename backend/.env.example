# AI services
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_PREDICTION_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-2.5-flash
GEMINI_CHAT_MODELS=gemini-2.0-flash-lite,gemini-2.0-flash,gemini-2.5-flash-lite
GEMINI_REQUEST_TIMEOUT_SECONDS=35
GEMINI_MODEL_COOLDOWN_SECONDS=45

GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
GROQ_REQUEST_TIMEOUT_SECONDS=35

# Clerk authentication
CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
DEV_MODE=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=replace-with-your-supabase-service-role-key
SUPABASE_DB_URL=postgresql+asyncpg://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Optional integrations
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMTP_USER=
SMTP_PASS=
ANTHROPIC_API_KEY=